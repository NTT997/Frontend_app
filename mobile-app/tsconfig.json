{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".", 
    "types": [
      "react",
      "react-native",
      "@types/react-native-dotenv"
    ],
    "strict": true,
    "paths": {
      "@/*": ["src/*"],
      "@/assets/*": ["assets/*"],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "babel.config.js",
    "App.tsx"
  ]
}
